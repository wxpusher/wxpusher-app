<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="16dp"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="@string/check_title"
        android:textColor="@color/check_text_color"
        android:textSize="20sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <LinearLayout
            android:id="@+id/check_items_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/check_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="10dp"
                android:text="@string/check_desc"
                android:textColor="@color/check_description_color"
                android:textSize="14sp" />

            <include
                android:id="@+id/notification_permission_item"
                layout="@layout/check_item" />

            <include
                android:id="@+id/notification_settings_item"
                layout="@layout/check_item" />

            <include
                android:id="@+id/autostart_item"
                layout="@layout/check_item" />

            <include
                android:id="@+id/background_running_item"
                layout="@layout/check_item" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:text="@string/check_tips"
                android:textColor="@color/check_description_color"
                android:textSize="14sp" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>