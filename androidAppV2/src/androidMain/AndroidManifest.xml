        <!--                    android:path="/message"-->
        <!--                    android:scheme="wxpusher" />-->
        <!--            </intent-filter>-->
        <!--        </activity>-->

        <activity
            android:name=".page.WebDetailActivity"
            android:configChanges="uiMode"
            android:exported="true"
            android:launchMode="singleTask" />

        <activity
            android:name=".kmp.page.unbind.WxpUnbindActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:screenOrientation="portrait" />

        <activity
            android:name=".kmp.page.scan.WxpScanActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/AppTheme.Scan" />

        <activity
            android:name=".kmp.page.useragreement.WxpUserAgreementActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!--        暂时不用长链接服务-->
        <!--        <service-->
        <!--            android:name=".push.ws.KeepWsConnectService"-->
        <!--            android:foregroundServiceType="remoteMessaging"-->
        <!--            tools:node="merge" />-->

        <service
            android:name=".kmp.push.ws.keepalive.KeepWsAliveService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <receiver
            android:name=".kmp.push.ws.keepalive.KeepWsAliveStartReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>


        <activity
            android:name=".TestActivity"
            android:exported="true">

        </activity>
        <activity
            android:name=".page.CheckActivity"
