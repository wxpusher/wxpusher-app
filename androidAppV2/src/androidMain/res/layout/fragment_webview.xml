<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/PageBg1"
    android:orientation="vertical">

    <!-- 第三方内容警告 Banner -->
    <LinearLayout
        android:id="@+id/thirdPartyBannerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/AccentColor"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp"
        android:visibility="gone">

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_warning"
            android:tint="@android:color/white" />

        <androidx.appcompat.widget.AppCompatTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="当前内容由第三方提供，与WxPusher无关"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_chevron_right"
            android:tint="@android:color/white" />

    </LinearLayout>

    <!-- WebView 容器 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/AccentColor"
            android:visibility="gone" />

        <!-- WebView -->
        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </FrameLayout>

    <!-- 底部工具栏 -->
    <LinearLayout
        android:id="@+id/webOptionView"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/PageBg1"
        android:elevation="8dp"
        android:orientation="vertical">

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:background="@color/Divider" />

        <!-- 按钮容器 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <!-- 后退按钮 -->
            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/backButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:enabled="false"
                android:src="@drawable/ic_chevron_left"
                android:tint="@color/text_fit_theme" />

            <!-- 前进按钮 -->
            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/forwardButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:enabled="false"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/text_fit_theme" />

            <!-- 刷新按钮 -->
            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/refreshButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_refresh"
                app:tint="@color/text_fit_theme" />

            <!-- 关闭按钮 -->
            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/closeButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                android:tint="@color/text_fit_theme" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>



