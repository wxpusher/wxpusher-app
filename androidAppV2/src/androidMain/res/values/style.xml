<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppStyle" parent="Theme.MaterialComponents.DayNight">
        <item name="android:colorPrimary">@color/colorPrimary</item>
        <item name="android:colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="android:colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/AccentColor</item>
        <item name="colorAccent">@color/AccentColor</item> <!-- checkboxes, text fields -->
        <item name="android:colorBackground">@color/white</item> <!-- background -->
        <item name="android:statusBarColor">@color/AccentColor</item>
        <item name="actionModeBackground">@color/AccentColorDark</item>
    </style>


    <style name="AppTheme.NoActionBar.TranslucentStatus" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowTranslucentStatus">true</item>
        <item name="actionMenuTextColor">#ffffff</item>
    </style>
</resources>